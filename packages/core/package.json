{
  "name": "@sx4im/chronos-core",
  "description": "Deterministic Simulation Testing core: PRNG (xoshiro256**), VirtualClock, MinHeap scheduler, SimEnv, strict guards, invariants, trace, RealEnv. Zero runtime dependencies.",
  "version": "0.1.5",
  "type": "module",
  "keywords": [
    "chronos",
    "deterministic-simulation-testing",
    "dst",
    "typescript",
    "testing",
    "prng",
    "xoshiro256",
    "virtual-clock",
    "simulation",
    "distributed-systems"
  ],
  "author": "sx4im <msaimshafique4664@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sx4im/chronos.git"
  },
  "bugs": {
    "url": "https://github.com/sx4im/chronos/issues"
  },
  "homepage": "https://github.com/sx4im/chronos#readme",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./real": {
      "import": "./dist/real.js",
      "types": "./dist/real.d.ts"
    },
    "./trace": {
      "import": "./dist/trace.js",
      "types": "./dist/trace.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/real.ts src/trace.ts --format esm --dts --clean"
  }
}
