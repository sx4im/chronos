{
  "$description": "Notion design tokens — Duply · https://duply.ai/notion/design-md (v alpha)",
  "colors": {
    "ink": {
      "$value": "#000000",
      "$type": "color",
      "$description": "All body text on light surfaces (measured from `body.color`)."
    },
    "on-primary": {
      "$value": "#f6f5f4",
      "$type": "color",
      "$description": "The label color on the primary CTA — a warm off-white rather than pure white."
    },
    "on-dark": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Hero headlines and any text on the navy hero (measured as the max-contrast h1 color)."
    },
    "neutral": {
      "$value": "#a39e98",
      "$type": "color",
      "$description": "Warm-gray secondary labels and muted UI text."
    },
    "neutral-strong": {
      "$value": "#615d59",
      "$type": "color",
      "$description": "Slightly darker warm-gray for sub-labels."
    },
    "neutral-soft": {
      "$value": "#78736f",
      "$type": "color",
      "$description": "Tertiary warm-gray captions / fine print."
    },
    "accent-blue": {
      "$value": "#097fe8",
      "$type": "color",
      "$description": "The primary action color — the \"Get Notion free\" CTA and inline highlights. The system's single saturated structural color."
    },
    "accent-blue-light": {
      "$value": "#62aef0",
      "$type": "color"
    },
    "accent-blue-deep": {
      "$value": "#0075de",
      "$type": "color",
      "$description": "Companion blues seen in product UI states, links, and status chips inside embedded mockups."
    },
    "accent-navy": {
      "$value": "#02093a",
      "$type": "color",
      "$description": "The deep hero background — the only large dark surface, closing the top of the page."
    },
    "accent-red": {
      "$value": "#f64932",
      "$type": "color"
    },
    "accent-orange": {
      "$value": "#ff6d00",
      "$type": "color"
    },
    "accent-amber": {
      "$value": "#ffb110",
      "$type": "color"
    },
    "accent-brown": {
      "$value": "#9c7054",
      "$type": "color"
    },
    "accent-violet": {
      "$value": "#9849e8",
      "$type": "color"
    },
    "accent-teal": {
      "$value": "#27918d",
      "$type": "color"
    },
    "surface-card": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "The default white content floor and card background measured directly from card elements."
    },
    "surface-cream": {
      "$value": "#fcf8f5",
      "$type": "color",
      "$description": "A barely-tinted warm off-white used for soft section blocks."
    },
    "surface-peach": {
      "$value": "#fff5ed",
      "$type": "color",
      "$description": "Tinted agent/feature tile background."
    },
    "surface-rose": {
      "$value": "#fef3f1",
      "$type": "color",
      "$description": "Tinted feature/quote tile background."
    },
    "surface-lilac": {
      "$value": "#f8f5fc",
      "$type": "color",
      "$description": "Tinted feature tile background."
    }
  },
  "typography": {
    "display-xl": {
      "$value": {
        "fontSize": "64px",
        "fontFamily": "NotionInter, Inter, sans-serif",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "-0.0332em"
      },
      "$type": "typography"
    },
    "display-lg": {
      "$value": {
        "fontSize": "54px",
        "fontFamily": "NotionInter, Inter, sans-serif",
        "fontWeight": 700,
        "lineHeight": 1.037,
        "letterSpacing": "-0.0347em"
      },
      "$type": "typography"
    },
    "label": {
      "$value": {
        "fontSize": "14px",
        "fontFamily": "NotionInter, Inter, sans-serif",
        "fontWeight": 400,
        "lineHeight": 1.429,
        "letterSpacing": "normal"
      },
      "$type": "typography"
    },
    "body": {
      "$value": {
        "fontSize": "16px",
        "fontFamily": "NotionInter, Inter, sans-serif",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "normal"
      },
      "$type": "typography"
    },
    "button": {
      "$value": {
        "fontSize": "16px",
        "fontFamily": "NotionInter, Inter, sans-serif",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "normal"
      },
      "$type": "typography"
    }
  },
  "rounded": {
    "xs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension"
    },
    "md": {
      "$value": "12px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "16px",
      "$type": "dimension"
    },
    "pill": {
      "$value": "9999px",
      "$type": "dimension"
    }
  },
  "spacing": {
    "xxs": {
      "$value": "4px",
      "$type": "dimension"
    },
    "xs": {
      "$value": "8px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "12px",
      "$type": "dimension"
    },
    "md": {
      "$value": "16px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "24px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "32px",
      "$type": "dimension"
    },
    "xxl": {
      "$value": "56px",
      "$type": "dimension"
    }
  },
  "$extensions": {
    "ai.duply": {
      "source": "https://duply.ai/notion/design-md",
      "version": "alpha",
      "components": {
        "top-nav": {
          "textColor": "{colors.on-dark}",
          "typography": "{typography.body}",
          "backgroundColor": "{colors.accent-navy}"
        },
        "hero-band": {
          "textColor": "{colors.on-dark}",
          "typography": "{typography.display-xl}",
          "backgroundColor": "{colors.accent-navy}"
        },
        "button-primary": {
          "padding": "5px 10px",
          "rounded": "{rounded.xs}",
          "textColor": "{colors.on-primary}",
          "typography": "{typography.button}",
          "backgroundColor": "{colors.accent-blue}"
        },
        "button-secondary": {
          "padding": "5px 10px",
          "rounded": "{rounded.xs}",
          "textColor": "{colors.on-dark}",
          "typography": "{typography.button}",
          "backgroundColor": "transparent"
        },
        "card": {
          "rounded": "{rounded.md}",
          "textColor": "{colors.ink}",
          "typography": "{typography.body}",
          "backgroundColor": "{colors.surface-card}"
        },
        "product-mockup-card": {
          "rounded": "{rounded.md}",
          "textColor": "{colors.ink}",
          "typography": "{typography.body}",
          "backgroundColor": "{colors.surface-card}"
        },
        "agent-tile-peach": {
          "rounded": "{rounded.md}",
          "textColor": "{colors.ink}",
          "typography": "{typography.label}",
          "backgroundColor": "{colors.surface-peach}"
        },
        "agent-tile-rose": {
          "rounded": "{rounded.md}",
          "textColor": "{colors.ink}",
          "typography": "{typography.label}",
          "backgroundColor": "{colors.surface-rose}"
        },
        "agent-tile-lilac": {
          "rounded": "{rounded.md}",
          "textColor": "{colors.ink}",
          "typography": "{typography.label}",
          "backgroundColor": "{colors.surface-lilac}"
        },
        "footer": {
          "textColor": "{colors.ink}",
          "typography": "{typography.label}",
          "backgroundColor": "{colors.surface-card}"
        }
      }
    }
  }
}